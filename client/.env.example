# Copy to .env.local (never commit .env.local)
# Google OAuth Web Client ID — must match server GOOGLE_CLIENT_ID
VITE_GOOGLE_CLIENT_ID=

# Must match server INBOXPILOT_API_SECRET when that variable is set (local or production build)
# VITE_INBOXPILOT_API_SECRET=

# If the API runs on a non-default port, set this to match root .env PORT (e.g. http://127.0.0.1:3042)
# VITE_API_PROXY_TARGET=http://127.0.0.1:3001
