# Server — use HTTPS + TLS termination in production (reverse proxy or PaaS)
PORT=3042
NODE_ENV=development
APP_BASE_URL=http://localhost:3042
# Behind nginx/Render/Fly: forward client IP correctly for rate limits
# TRUST_PROXY=true

# API auth: required in production (see app.js). Send header x-inboxpilot-key or Authorization: Bearer
# Never commit real values. For local dev with a secret set, either paste the same value into
# dashboard/index.html (window.INBOXPILOT_API_SECRET) for trusted machines only, or use a reverse proxy to inject the header.
# INBOXPILOT_API_SECRET=
# ALLOW_LOCALHOST_API_WITHOUT_KEY=true

# Database — Postgres in production, or `pglite` for local embedded DB
DATABASE_URL=postgresql://user:pass@localhost:5432/inboxpilot
# DATABASE_URL=pglite
# PGLITE_DATA_DIR=./db/.pglite-data
# DATABASE_SSL=true

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_DRAFT_MODEL=gpt-4o
OPENAI_CLASSIFY_MODEL=gpt-4o
AUTO_SEND_THRESHOLD=0.90

# Learned memory: reuse past drafts/classifications when inbound text matches stored patterns (fewer OpenAI calls). Set INBOXPILOT_LEARNED_MEMORY=0 to disable.
# INBOXPILOT_MEMORY_MIN_SCORE=10
# INBOXPILOT_MEMORY_MIN_RATIO=0.32
# INBOXPILOT_MEMORY_HUMAN_MIN_SCORE_EXTRA=4

# Nylas (production: API + webhook secret required; without secret, prod rejects webhooks)
NYLAS_API_KEY=
NYLAS_GRANT_ID=
NYLAS_WEBHOOK_SECRET=

# Webhook auto-send: explicit opt-in. When false/unset, inbound mail is classified + drafted
# but never auto-sent from the webhook — always Review Queue until someone enables this after KB testing.
AUTO_SEND_FROM_WEBHOOK=false

# Optional: override default tenant for webhook ingestion (single-tenant MVP)
# WEBHOOK_TENANT_ID=default

# Optional error tracking (package: @sentry/node — server.js + app.js when DSN set)
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0

# DB scripts: prefer psql for multi-statement SQL (db:setup, db:migrate)
# PSQL_PATH=psql
# SQL_APPLY_SKIP_PSQL=false

# Future multi-tenant: store per-tenant provider keys encrypted at rest (e.g. pgcrypto + KMS);
# never return raw secrets from the API (today only booleans like openAiKeyConfigured are exposed).
