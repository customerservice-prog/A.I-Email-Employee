# Client (Vite): create client/.env.local with the Web client ID from Google Cloud Console:
# VITE_GOOGLE_CLIENT_ID=....apps.googleusercontent.com

# =============================================================================
# Local development (copy to .env — never commit real secrets)
# =============================================================================
# API port — keep in sync with Vite: client dev reads ../.env PORT for the proxy target
PORT=3001
NODE_ENV=development
APP_BASE_URL=http://localhost:3001

# Database — use Postgres for production; `pglite` is dev-only (see lib/config.js).
DATABASE_URL=postgresql://user:pass@localhost:5432/inboxpilot
# DATABASE_URL=pglite
# PGLITE_DATA_DIR=./db/.pglite-data
# DATABASE_SSL=true

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_DRAFT_MODEL=gpt-4o
OPENAI_CLASSIFY_MODEL=gpt-4o
AUTO_SEND_THRESHOLD=0.90

# Nylas (required when NODE_ENV=production)
NYLAS_API_KEY=
# Legacy single-mailbox: grant for tenant "default" only (per-user grants use Connect below)
NYLAS_GRANT_ID=
# Hosted auth (Connect Gmail) — create an app in Nylas dashboard; redirect URI must be APP_BASE_URL/api/auth/nylas/callback
NYLAS_CLIENT_ID=
NYLAS_WEBHOOK_SECRET=
# Set true only if every tenant should share NYLAS_GRANT_ID from env (normally leave unset)
# NYLAS_USE_ENV_GRANT_FALLBACK=true

# Google Sign-In (server verifies GIS JWTs)
GOOGLE_CLIENT_ID=

# Password reset emails (optional). If SMTP_HOST is unset, reset links are not emailed (dev may still get devResetUrl from the API).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="InboxPilot <no-reply@yourdomain.com>"
# APP_NAME=InboxPilot

# Where the browser should land after Nylas OAuth (defaults to APP_BASE_URL). Use this if the API and Vite dev UI use different ports.
# CLIENT_BASE_URL=http://localhost:3000

# API auth — optional in development; REQUIRED in production (min 24 chars). Generate: npm run gen:api-secret
# INBOXPILOT_API_SECRET=
# If set: add the same value to client/.env.local as VITE_INBOXPILOT_API_SECRET for npm run dev / production builds
# ALLOW_LOCALHOST_API_WITHOUT_KEY=true

# Dashboard: run npm run db:prepare (schema + seed + migrations), then sign in at /login (Google) or POST /api/auth/register.
# Tenant comes from the session cookie — the browser must not rely on x-tenant-id.

# Integration tests / automation only — disabled in production unless ALLOW_MACHINE_API_KEY=true
# INBOXPILOT_MACHINE_KEY=
# INBOXPILOT_MACHINE_TENANT=default

# Set true in production behind HTTPS
# COOKIE_SECURE=true

# Behind nginx/Render/Fly: forward client IP for rate limits
# TRUST_PROXY=true

# Extra browser origins allowed to call the API (comma-separated), in addition to APP_BASE_URL
# CORS_ORIGINS=https://admin.example.com

# Webhook auto-send: explicit opt-in after KB testing
AUTO_SEND_FROM_WEBHOOK=false

# Optional: default tenant for webhook ingestion (single-tenant MVP)
# WEBHOOK_TENANT_ID=default

# Multi-tenant production: set true so Nylas events whose grant_id is not stored on any tenant
# are ignored (never attributed to WEBHOOK_TENANT_ID / default). Prevents cross-tenant mail bleed.
# WEBHOOK_DENY_UNKNOWN_GRANT=true

# Learned memory (set INBOXPILOT_LEARNED_MEMORY=0 to disable)
# INBOXPILOT_MEMORY_MIN_SCORE=10
# INBOXPILOT_MEMORY_MIN_RATIO=0.32
# INBOXPILOT_MEMORY_HUMAN_MIN_SCORE_EXTRA=4

# Optional error tracking
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0

# DB scripts
# PSQL_PATH=psql
# SQL_APPLY_SKIP_PSQL=false

# =============================================================================
# Production checklist (set on the host / secret manager — do not commit)
# =============================================================================
#
# NODE_ENV=production
#
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/inboxpilot
#   - Must be real Postgres; pglite is rejected when NODE_ENV=production.
#   - After first deploy: npm run db:prepare (or db:setup + db:migrate); each release: npm run db:migrate
#
# INBOXPILOT_API_SECRET=<output of: npm run gen:api-secret>
#   - Send as header x-inboxpilot-key or Authorization: Bearer <secret> on /api/*
#
# APP_BASE_URL=https://your-app.example.com
#   - Used for CORS; add CORS_ORIGINS if the UI is on other HTTPS origins
#
# TRUST_PROXY=true
#   - Set when TLS terminates at a reverse proxy (nginx, Fly, Render, etc.)
#
# NYLAS_API_KEY=...
# NYLAS_GRANT_ID=...
# NYLAS_WEBHOOK_SECRET=...
#   - Webhook URL in Nylas: https://<api-host>/api/webhook
#   - With NODE_ENV=production, unsigned webhooks are rejected when secret is set
#
# WEBHOOK_DENY_UNKNOWN_GRANT=true
#   - Strongly recommended when multiple customers each have their own Nylas grant
#
# OPENAI_API_KEY=sk-...
#
# Full step-by-step: docs/DEPLOY.md
# Automated local prep (Docker + secret + DB): npm run setup:proceed
